# Navidrome AI 歌单生成器 - 环境变量配置
# 复制本文件为 .env 并填入实际值（.env 已在 .gitignore 中，不会被提交）

# ========== 必需 ==========
# Navidrome 服务器地址（末尾加 /）
NAVIDROME_URL=http://127.0.0.1:4533/
# Navidrome 用户名
NAVIDROME_USER=admin
# Navidrome 密码
NAVIDROME_PASS=your_navidrome_password
# Web UI 访问密码（自己设一个，与 Navidrome 密码无关）
LOGIN_PASSWORD=your_web_password

# ========== 可选 ==========
# 服务端口（默认 8899）
# PORT=8899
# 搜索超时秒数（默认 10）
# SEARCH_TIMEOUT=10

# ========== 下载配置（可选）==========
# 未匹配歌曲下载目录（容器内路径，需在 docker-compose 映射到宿主机，
# 并让 Navidrome 也挂载该目录，下载后即可被 Navidrome 扫描入库）
# DOWNLOAD_DIR=/app/downloads
# 下载源（当前仅酷我）
# DOWNLOAD_SOURCE=酷我
